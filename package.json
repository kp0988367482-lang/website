{
    "name": "seoualmate-workspace",
    "private": true,
    "workspaces": [
        "apps/*"
    ],
    "scripts": {
        "dev": "cd apps/landing && npm run dev",
        "dev:core": "cd apps/core/frontend && npm run dev",
        "dev:admin": "cd apps/admin && npm run dev",
        "dev:landing": "cd apps/landing && npm run dev",
        "build:core": "cd apps/core/frontend && npm run build",
        "build:admin": "cd apps/admin && npm run build",
        "build:landing": "cd apps/landing && npm run build",
        "api:core": "cd apps/core/backend && .venv/bin/python -m uvicorn main:app --reload --host 127.0.0.1 --port 8000",
        "install:all": "npm install && cd apps/core/frontend && npm install"
    }
}
